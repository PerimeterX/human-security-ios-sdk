essionQueueDelegate","fragments":[{"text":"static","kind":"keyword"},{"text":" ","kind":"text"},{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"urlSessionQueueDelegate","kind":"identifier"},{"text":": ","kind":"text"},{"text":"OperationQueue","kind":"typeIdentifier","preciseIdentifier":"c:objc(cs)NSOperationQueue"},{"text":"?","kind":"text"}],"abstract":[{"type":"text","text":"The "},{"type":"codeVoice","code":"OperationQueue"},{"type":"text","text":" that should be used by the SDK."}],"navigatorTitle":[{"text":"urlSessionQueueDelegate","kind":"identifier"}],"title":"urlSessionQueueDelegate","url":"\/documentation\/human\/hsautomaticinterceptorpolicy\/urlsessionqueuedelegate","kind":"symbol","type":"topic","role":"symbol"},"doc://com.perimeterx.mobile-sdk/objc(pl)NSCopying":{"type":"unresolvable","title":"NSCopying","identifier":"doc:\/\/com.perimeterx.mobile-sdk\/objc(pl)NSCopying"},"doc://com.perimeterx.mobile-sdk/documentation/HUMAN/How_to_upgrade_from_v3":{"title":"How to upgrade from v3","role":"article","identifier":"doc:\/\/com.perimeterx.mobile-sdk\/documentation\/HUMAN\/How_to_upgrade_from_v3","abstract":[{"text":"There are few major changes in the SDK’s API. In this article we will cover all of them.","type":"text"}],"kind":"article","url":"\/documentation\/human\/how_to_upgrade_from_v3","type":"topic"},"doc://com.perimeterx.mobile-sdk/SH":{"type":"unresolvable","title":"Swift.Hashable","identifier":"doc:\/\/com.perimeterx.mobile-sdk\/SH"},"doc://com.perimeterx.mobile-sdk/documentation/HUMAN/HSAutomaticInterceptorPolicy/urlSessionDelegate":{"identifier":"doc:\/\/com.perimeterx.mobile-sdk\/documentation\/HUMAN\/HSAutomaticInterceptorPolicy\/urlSessionDelegate","fragments":[{"text":"static","kind":"keyword"},{"text":" ","kind":"text"},{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"urlSessionDelegate","kind":"identifier"},{"text":": ","kind":"text"},{"preciseIdentifier":"c:objc(pl)NSURLSessionDelegate","text":"URLSessionDelegate","kind":"typeIdentifier"},{"text":"?","kind":"text"}],"abstract":[{"type":"text","text":"The "},{"type":"codeVoice","code":"URLSessionDelegate"},{"type":"text","text":" that should be used by the SDK. Default is "},{"type":"codeVoice","code":"nil"},{"type":"text","text":" (the SDK will be the delegate). The SDK implements "},{"type":"codeVoice","code":"willPerformHTTPRedirection"},{"type":"text","text":" and "},{"type":"codeVoice","code":"needNewBodyStream"},{"type":"text","text":" function in the "},{"type":"codeVoice","code":"URLSessionDelegate"},{"type":"text","text":". However, if your "},{"type":"codeVoice","code":"URLSessionDelegate"},{"type":"text","text":" implements other functions, like "},{"type":"codeVoice","code":"didReceiveChallenge"},{"type":"text","text":", then you should provide your own delegate."}],"navigatorTitle":[{"text":"urlSessionDelegate","kind":"identifier"}],"title":"urlSessionDelegate","url":"\/documentation\/human\/hsautomaticinterceptorpolicy\/urlsessiondelegate","kind":"symbol","type":"topic","role":"symbol"},"doc://com.perimeterx.mobile-sdk/s23CustomStringConvertibleP":{"title":"Swift.CustomStringConvertible","identifier":"doc:\/\/com.perimeterx.mobile-sdk\/s23CustomStringConvertibleP","type":"unresolvable"},"doc://com.perimeterx.mobile-sdk/documentation/HUMAN/HSAutomaticInterceptorType/interceptWithDelayedResponse":{"identifier":"doc:\/\/com.perimeterx.mobile-sdk\/documentation\/HUMAN\/HSAutomaticInterceptorType\/interceptWithDelayedResponse","fragments":[{"text":"case","kind":"keyword"},{"text":" ","kind":"text"},{"text":"interceptWithDelayedResponse","kind":"identifier"}],"abstract":[{"text":"Same as ","type":"text"},{"identifier":"doc:\/\/com.perimeterx.mobile-sdk\/documentation\/HUMAN\/HSAutomaticInterceptorType\/intercept","isActive":true,"type":"reference"},{"text":". The SDK delays the error response to your app until the user solve or cancel the challenge. In order to delay the request’s response to your handler until the user interacts with the challenge, you must disable the request’s timeout. Otherwise, your handler will receive a timeout error and you might not know that your request was blocked nor the challenge was solved\/cancelled.","type":"text"}],"navigatorTitle":[{"kind":"identifier","text":"HSAutomaticInterceptorTypeInterceptWithDelayedResponse"}],"title":"HSAutomaticInterceptorType.interceptWithDelayedResponse","url":"\/documentation\/human\/hsautomaticinterceptortype\/interceptwithdelayedresponse","kind":"symbol","type":"topic","role":"symbol"},"doc://com.perimeterx.mobile-sdk/s28CustomDebugStringConvertibleP":{"title":"Swift.CustomDebugStringConvertible","identifier":"doc:\/\/com.perimeterx.mobile-sdk\/s28CustomDebugStringConvertibleP","type":"unresolvable"},"doc://com.perimeterx.mobile-sdk/objc(pl)NSObject":{"identifier":"doc:\/\/com.perimeterx.mobile-sdk\/objc(pl)NSObject","type":"unresolvable","title":"ObjectiveC.NSObjectProtocol"},"doc://com.perimeterx.mobile-sdk/documentation/HUMAN/HSAutomaticInterceptorPolicy":{"navigatorTitle":[{"text":"HSAutomaticInterceptorPolicy","kind":"identifier"}],"kind":"symbol","role":"symbol","url":"\/documentation\/human\/hsautomaticinterceptorpolicy","title":"HSAutomaticInterceptorPolicy","identifier":"doc:\/\/com.perimeterx.mobile-sdk\/documentation\/HUMAN\/HSAutomaticInterceptorPolicy","fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"text":"HSAutomaticInterceptorPolicy","kind":"identifier"}],"type":"topic","abstract":[{"type":"text","text":"The policy that define the behaviour of the Automatic Interceptor."}]},"doc://com.perimeterx.mobile-sdk/documentation/HUMAN/HSAutomaticInterceptorType/interceptAndRetryRequest":{"role":"symbol","identifier":"doc:\/\/com.perimeterx.mobile-sdk\/documentation\/HUMAN\/HSAutomaticInterceptorType\/interceptAndRetryRequest","url":"\/documentation\/human\/hsautomaticinterceptortype\/interceptandretryrequest","type":"topic","fragments":[{"kind":"keyword","text":"case"}